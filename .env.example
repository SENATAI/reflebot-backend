REFLEBOT_DEBUG=true
REFLEBOT_BASE_URL=http://localhost:8080
REFLEBOT_SECRET_KEY=your-secret-key-here
REFLEBOT_TELEGRAM_SECRET_TOKEN=your-telegram-bot-token-here
REFLEBOT_TELEGRAM_BOT_USERNAME=your_bot_username
REFLEBOT_DEFAULT_DEADLINE=24
REFLEBOT_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

REFLEBOT_DB__PROVIDER=postgresql+psycopg_async
REFLEBOT_DB__HOST=localhost
REFLEBOT_DB__PORT=5432
REFLEBOT_DB__USER=postgres
REFLEBOT_DB__PASSWORD=password
REFLEBOT_DB__NAME=reflebot
REFLEBOT_DB__SCHEME=public

REFLEBOT_RABBITMQ__HOST=localhost
REFLEBOT_RABBITMQ__PORT=5672
REFLEBOT_RABBITMQ__USER=reflebot
REFLEBOT_RABBITMQ__PASSWORD=password
REFLEBOT_RABBITMQ__VHOST=/
REFLEBOT_RABBITMQ__DEFAULT_QUEUE=celery
REFLEBOT_RABBITMQ__REFLECTION_PROMPT_QUEUE=bot.reflection-prompts
REFLEBOT_RABBITMQ__DELIVERY_RESULT_QUEUE=backend.notification-results
REFLEBOT_RABBITMQ__NOTIFICATIONS_EXCHANGE=reflebot.notifications
REFLEBOT_RABBITMQ__NOTIFICATION_RESULTS_EXCHANGE=reflebot.notification-results
REFLEBOT_RABBITMQ__REFLECTION_PROMPT_ROUTING_KEY=reflection_prompt.send
REFLEBOT_RABBITMQ__DELIVERY_RESULT_ROUTING_KEY=reflection_prompt.result

REFLEBOT_CELERY__TASK_DEFAULT_QUEUE=celery
REFLEBOT_CELERY__BEAT_SCHEDULE_SCAN_INTERVAL_SECONDS=60
REFLEBOT_CELERY__SCAN_BATCH_SIZE=500
REFLEBOT_CELERY__PUBLISH_BATCH_SIZE=500
REFLEBOT_CELERY__RETRY_FAILED_INTERVAL_SECONDS=300
REFLEBOT_CELERY__RETRY_FAILED_BACKOFF_SECONDS=300
REFLEBOT_CELERY__RETRY_FAILED_MAX_ATTEMPTS=3
REFLEBOT_CELERY__TASK_TIME_LIMIT=60
REFLEBOT_CELERY__TASK_SOFT_TIME_LIMIT=45
REFLEBOT_CELERY__SCAN_LOOKBACK_HOURS=168
